# ------------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored; never commit real secrets.
# ------------------------------------------------------------------

# MongoDB connection string.
# Local dev:  mongodb://localhost:27017/portfolio
# Atlas:      mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority
# (keep the "/portfolio" database name in the path)
MONGODB_URI=

# Admin login (single admin, no user collection).
ADMIN_USERNAME=admin
# Generate with:  npm run hash-password -- "your-password-here"
# IMPORTANT (local .env files only): escape every $ in the hash as \$ —
# Next.js env loading expands $VAR references, even inside quotes.
# The hash-password script prints the correctly escaped line to paste.
# On Vercel's dashboard, paste the RAW hash (no escaping).
# Example: ADMIN_PASSWORD_HASH=\$2a\$12\$abc...
ADMIN_PASSWORD_HASH=

# NextAuth. Generate the secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
# The app's absolute URL: http://localhost:3000 in dev, your domain in prod.
NEXTAUTH_URL=http://localhost:3000

# Absolute public URL used for SEO metadata, sitemap.xml and robots.txt.
SITE_URL=http://localhost:3000

# Cloudinary — stores every upload (project images, hero photo, resume PDF).
# Find these on the Cloudinary dashboard. CLOUD_NAME is the account's "Cloud
# name" (NOT an API key's "Key Name"). The API secret has no $ so it needs no
# escaping locally; paste values raw on Vercel too.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
